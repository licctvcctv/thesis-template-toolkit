  P077 style='Normal' align=None runs=0 num=None text=''
  P078 style='Body text|1' align='justify' runs=30 num=None text='要求：绪论包括本论文（设计）课题研究背景、国内外研究现状、研究目的等基本内容。研究背景应明确地提出论文（设计）研究所针对的科学、生产和经济建设的问题，指出研究这些问题的意义。国内外研究现状主要回顾与所研究课题相关的学科背景，相关领域的研究…'
  P079 style='Normal' align=None runs=0 num=None text=''
  P080 style='Normal' align='center' runs=0 num=None text=''
