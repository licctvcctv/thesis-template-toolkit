    {
      "kind": "paragraph",
      "index": 490,
      "text": "王琦. 中医体质学说研究现状与展望[J]. 中国中医基础医学杂志, 2002,8(2):6-15.",
      "style": "endnote text",
      "alignment": "justify",
      "numbering": {
