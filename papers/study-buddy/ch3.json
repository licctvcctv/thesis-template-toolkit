                "caption": "表3-7 用户表（users）",
                "headers": [
                  "字段名",
                  "类型",
                  "约束",
                  "说明"
                ],
                "rows": [
                  [
                    "id",
                    "INTEGER",
                    "PK",
                    "用户主键"
                  ],
                  [
                    "openid",
                    "TEXT",
