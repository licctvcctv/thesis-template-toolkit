                    "密码哈希值"
                  ],
                  [
                    "nickname",
                    "TEXT",
                    "",
                    "用户昵称"
                  ],
                  [
                    "avatar",
                    "TEXT",
                    "",
                    "头像路径"
                  ],
                  [
                    "tags",
                    "TEXT",
                    "JSON",
                    "学习标签"
                  ],
                  [
                    "bio",
                    "TEXT",
                    "",
                    "个人简介"
                  ],
                  [
